EVERYTIME_ID=your_id_here
EVERYTIME_PASSWORD=your_password_here

# Optional API mode.
# Paste the Cookie header value from DevTools Copy as cURL here.
# Example shape only:
# EVERYTIME_COOKIE=_ga=...; x-et-device=...; etsid=...
EVERYTIME_COOKIE=

# Keep this slow. Do not set it too low.
CRAWL_MIN_DELAY_SECONDS=2.0
CRAWL_MAX_DELAY_SECONDS=5.0
